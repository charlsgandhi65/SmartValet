<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back_arrow"
                android:padding="8dp"
                android:background="@drawable/rounded_card_background"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Manage Staff for Event"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:gravity="center_vertical" />
        </LinearLayout>

        <!-- Selected Event -->
        <TextView
            android:id="@+id/tvSelectedEvent"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="No event selected"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/rounded_input_background"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnSelectEvent"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Select Event"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/rounded_button_border"
            android:layout_marginBottom="24dp" />

        <!-- Mode Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SELECT OPTION"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <RadioGroup
            android:id="@+id/radioGroupMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_input_background"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/radioAssignExisting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Assign Existing Staff Member"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:paddingVertical="8dp"
                android:checked="true" />

            <RadioButton
                android:id="@+id/radioCreateNew"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Create New Staff Member"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:paddingVertical="8dp" />
        </RadioGroup>

        <!-- Assign Existing Staff Form -->
        <LinearLayout
            android:id="@+id/layoutAssignExistingForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ASSIGN EXISTING STAFF"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvSelectedStaff"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="No staff selected"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="@drawable/rounded_input_background"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnSelectExistingStaff"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Select Staff Member"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/rounded_button_border"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnAssignStaff"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Assign Staff to Event"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/rounded_button_border" />
        </LinearLayout>

        <!-- Create New Staff Form -->
        <LinearLayout
            android:id="@+id/layoutCreateNewForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CREATE NEW STAFF MEMBER"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp" />

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMAIL"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/editEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Enter email"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:inputType="textEmailAddress"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="@drawable/rounded_input_background"
                android:layout_marginBottom="20dp" />

            <!-- Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PASSWORD"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/editPassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Enter password"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:inputType="textPassword"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="@drawable/rounded_input_background" />

            <CheckBox
                android:id="@+id/cbShowPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show password"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp" />

            <!-- Full Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FULL NAME"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/editFullName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Enter full name"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="@drawable/rounded_input_background"
                android:layout_marginBottom="20dp" />

            <!-- Contact Number -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTACT NUMBER"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:background="@drawable/rounded_input_background"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="+91 "
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="8dp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/editContactNumber"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Enter 10 digit number"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:inputType="phone"
                    android:maxLength="10"
                    android:paddingEnd="20dp"
                    android:background="@android:color/transparent" />
            </LinearLayout>

            <!-- Location -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOCATION"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/editLocation"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Enter location"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="@drawable/rounded_input_background"
                android:layout_marginBottom="20dp" />

            <!-- Age -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AGE"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/editAge"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Enter age (18+)"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:inputType="number"
                android:maxLength="2"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="@drawable/rounded_input_background"
                android:layout_marginBottom="20dp" />

            <!-- Experience Level -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXPERIENCE LEVEL"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerExperience"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="@drawable/rounded_input_background"
                android:layout_marginBottom="32dp" />

            <!-- Create Button -->
            <Button
                android:id="@+id/btnCreateStaff"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Create Staff"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/rounded_button_border" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
