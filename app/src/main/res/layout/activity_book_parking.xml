<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back_arrow"
                android:padding="8dp"
                android:background="@drawable/rounded_card_background"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Book Parking"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:gravity="center_vertical" />
        </LinearLayout>

        <!-- Event Info -->
        <TextView
            android:id="@+id/tvEventName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Event: Loading..."
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvEventDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date: Loading..."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Vehicle Number -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VEHICLE NUMBER"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editVehicleNumber"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Enter vehicle registration number"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/rounded_input_background"
            android:layout_marginBottom="20dp" />

        <!-- Vehicle Model -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VEHICLE MODEL"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editVehicleModel"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="e.g., Honda Civic"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/rounded_input_background"
            android:layout_marginBottom="20dp" />

        <!-- Vehicle Color -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VEHICLE COLOR"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editVehicleColor"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="e.g., Red"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/rounded_input_background"
            android:layout_marginBottom="20dp" />

        <!-- Parking Time -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PARKING TIME (HH:mm)"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editParkingTime"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="e.g., 14:30"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:inputType="time"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/rounded_input_background"
            android:layout_marginBottom="32dp" />

        <!-- Book Button -->
        <Button
            android:id="@+id/btnBookParking"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Book Parking"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/rounded_button_border" />

    </LinearLayout>
</ScrollView>

