<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back_arrow"
                android:padding="8dp"
                android:background="@drawable/rounded_card_background"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Create Event"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:gravity="center_vertical" />
        </LinearLayout>

        <!-- Event Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EVENT NAME"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editEventName"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Enter event name"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/rounded_input_background"
            android:layout_marginBottom="20dp" />

        <!-- Event Address -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EVENT ADDRESS"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editEventAddress"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Enter full address"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/rounded_input_background"
            android:inputType="textPostalAddress"
            android:layout_marginBottom="20dp" />

        <!-- Event Date -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EVENT DATE (YYYY-MM-DD)"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editEventDate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="2024-12-15"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/rounded_input_background"
            android:layout_marginBottom="20dp" />

        <!-- Hours of Event -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HOURS OF EVENT"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editHours"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="6"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/rounded_input_background"
            android:inputType="number"
            android:layout_marginBottom="20dp" />

        <!-- Total Vehicle Spots -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TOTAL VEHICLE SPOTS"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editSpots"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="250"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/rounded_input_background"
            android:inputType="number"
            android:layout_marginBottom="20dp" />

        <!-- Base Price -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BASE PRICE (₹)"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editBasePrice"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="100"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/rounded_input_background"
            android:inputType="numberDecimal"
            android:layout_marginBottom="20dp" />

        <!-- Extra Charge Per Hour (after 4 hours) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EXTRA CHARGE PER HOUR (₹)"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editExtraChargePerHour"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="50"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/rounded_input_background"
            android:inputType="numberDecimal"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Applied after 4 hours of parking"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:layout_marginBottom="32dp" />

        <!-- Create Button -->
        <Button
            android:id="@+id/btnCreateEvent"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Create Event"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/rounded_button_border" />

    </LinearLayout>
</ScrollView>

